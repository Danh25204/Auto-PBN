{
  "name": "auto-pbn-server",
  "version": "1.0.0",
  "description": "Auto PBN Poster — Express backend",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "restart": "powershell -Command \"$p = Get-NetTCPConnection -LocalPort 3001 -EA SilentlyContinue | Select -First 1; if ($p -and $p.OwningProcess -gt 4) { Stop-Process -Id $p.OwningProcess -Force; Start-Sleep -m 600 }; node src/index.js\""
  },
  "dependencies": {
    "axios": "^1.7.2",
    "axios-retry": "^4.4.0",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.25.0",
    "p-queue": "^8.0.1",
    "puppeteer": "^24.37.5",
    "uuid": "^10.0.0",
    "xmlrpc": "^1.3.2",
    "zod": "^3.23.8"
  }
}
